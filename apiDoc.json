[
    {
        "name": "Sign Up",
        "url": "https://quiz-app-backend-api.herokuapp.com/auth/signup",
        "header": {
            "Content-Type": "application/json"
        },
        "type": "POST",
        "body": {
            "phno": "<user phone number with 91 at begining, example '917589763452'>"
        },
        "response": {
            "auth": true,
            "token": "<A JWT token from server>"
        }
    },
    {
        "name": "Sign In",
        "url": "https://quiz-app-backend-api.herokuapp.com/auth/signin",
        "header": {
            "Content-Type": "application/json"
        },
        "type": "POST",
        "body": {
            "phno": "<user phone number with 91 at begining, example '917589763452'>"
        },
        "response": {
            "auth": true,
            "token": "<A JWT token from server>"
        }
    },
    {
        "name": "User Details",
        "url": "https://quiz-app-backend-api.herokuapp.com/user/details",
        "header": {
            "Content-Type": "application/json",
            "x-access-token": "<JWT token>"
        },
        "type": "GET",
        "response": {
            "userFound": true,
            "userDetails": {
                "_id": "<id of user>",
                "phno": "<user phone number>",
            }
        }
    },
    {
        "name": "Get Exams Array",
        "url": "https://quiz-app-backend-api.herokuapp.com/exam/getExams?className=<class>&type=<exam_type>",
        "header": {
            "Content-Type": "application/json",
            "x-access-token": "<JWT token>"
        },
        "type": "GET",
        "response": "<Array of chapter wise exams>"
    }
    
    {
        "name": "Register user for a Exam",
        "url": "https://quiz-app-backend-api.herokuapp.com/exam/register",
        "header": {
            "Content-Type": "application/json",
            "x-access-token": "<JWT token>"
        },
        "type": "POST",
        "body": {
            "exam_id": "Id of exam"
        },
        "response": {
            "user_registered": true,
            "message": "User successfully registered for exam"
        }
    }
    
]